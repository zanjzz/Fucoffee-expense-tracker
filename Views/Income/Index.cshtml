@model IEnumerable<Fucoffee.Models.Income>

@{
    ViewData["Title"] = "Income Records";
}

<div class="page-wrapper">
    <div class="main-content">
        <div class="header-actions">
            <h2>Income Records</h2>
            <a asp-action="Create" class="btn-add">
                <i class="fas fa-plus"></i> Add Income
            </a>
        </div>

        <!-- Filter bar: Search (left) | Date picker + Clear (right) -->
        <div class="filter-bar">
            <input type="text" id="searchIncomeInput" class="search-input" placeholder="Search by source, amount, description..." />
            <div class="filter-controls">
                <input type="date" id="filterDate" />
                <button id="clearDateFilter" class="filter-btn">
                    <i class="fas fa-undo-alt"></i> Clear
                </button>
            </div>
        </div>

        <!-- Scrollable Table Wrapper -->
        <div class="scrollable-table-wrapper">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="incomeTableBody">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Source</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td class="description-cell">@item.Description</td>
                                <td class="date-cell" data-raw="@item.Date.ToString("yyyy-MM-dd")">
                                    @item.Date.ToString("MMM dd, yyyy")
                                </td>
                                <td class="table-actions">
                                    <a asp-action="Edit" asp-route-id="@item.IncomeId" class="btn-edit btn-sm">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.IncomeId" class="btn-delete btn-sm">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="quick-actions">
            <a asp-controller="Dashboard" asp-action="Index" class="btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchIncomeInput');
        const datePicker = document.getElementById('filterDate');
        const clearBtn = document.getElementById('clearDateFilter');
        const tableRows = document.querySelectorAll('#incomeTableBody tr');

        function applyFilters() {
            const searchTerm = searchInput.value.toLowerCase();
            const selectedDate = datePicker.value;

            tableRows.forEach(row => {
                const rowText = row.innerText.toLowerCase();
                const dateCell = row.querySelector('.date-cell');
                const rowDate = dateCell ? dateCell.getAttribute('data-raw') : '';
                const matchesSearch = rowText.includes(searchTerm);
                const matchesDate = (selectedDate === '' || rowDate === selectedDate);
                row.style.display = (matchesSearch && matchesDate) ? '' : 'none';
            });
        }

        // Live search on typing
        searchInput.addEventListener('keyup', applyFilters);
        // Filter when date is changed
        datePicker.addEventListener('change', applyFilters);
        // Clear both filters
        clearBtn.addEventListener('click', () => {
            datePicker.value = '';
            searchInput.value = '';
            applyFilters();
        });
    </script>
}