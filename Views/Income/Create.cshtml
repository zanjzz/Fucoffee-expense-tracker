@{
    ViewData["MainClass"] = "form-only-layout";
}
@model Fucoffee.Models.Income

<div class="form-page-container">
    <div class="floating-form-card">
        <h2>Add Income</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="Source">Source</label>
                <input asp-for="Source" placeholder="e.g., Freelance, Salary, Gift" />
            </div>
            
            <div class="form-group">
                <label asp-for="Amount">Amount</label>
                <input asp-for="Amount" type="number" step="0.01" placeholder="0.00" />
            </div>
            
            <div class="form-group">
                <label asp-for="Description">Description (Optional)</label>
                <input asp-for="Description" placeholder="Add notes..." />
            </div>
            
            <div class="form-group">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" type="date" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="fas fa-save"></i> Save Income
                </button>
                <a asp-action="Index" class="btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.validation-summary-errors').forEach(summary => {
            if (summary.innerText.trim() === '') summary.style.display = 'none';
        });
    </script>
}