@model Fucoffee.Models.ViewModels.ReportViewModel

@{
    ViewData["Title"] = "Reports";
}

<div class="main-content">
    <h2><i class="fas fa-chart-bar"></i> Reports</h2>

    <!-- Global Date Range Filter (unchanged) -->
    <form method="get" asp-action="Index">
        <div class="filter-group">
            <div class="filter-field">
                <label><i class="fas fa-calendar-alt"></i> Start Date</label>
                <input type="date" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-field">
                <label><i class="fas fa-calendar-check"></i> End Date</label>
                <input type="date" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn-primary"><i class="fas fa-filter"></i> Filter</button>
                <a asp-action="Index" class="btn-secondary"><i class="fas fa-undo-alt"></i> Clear</a>
            </div>
        </div>
    </form>

    <!-- Summary Cards -->
    <div class="stat-cards">
        <div class="stat-card">
            <p><i class="fas fa-arrow-up"></i> Total Income</p>
            <h3 class="positive">@Model.TotalIncome.ToString("C")</h3>
        </div>
        <div class="stat-card">
            <p><i class="fas fa-arrow-down"></i> Total Expenses</p>
            <h3 class="negative">@Model.TotalExpenses.ToString("C")</h3>
        </div>
        <div class="stat-card">
            <p><i class="fas fa-chart-line"></i> Net Profit</p>
            <h3 class="@(Model.NetProfit >= 0 ? "positive" : "negative")">
                @Model.NetProfit.ToString("C")
            </h3>
        </div>
    </div>

    <!-- INCOME TABLE with its own filter + scroll -->
    <div style="margin-bottom: 2rem;">
        <h3><i class="fas fa-coffee"></i> Income Records</h3>
        <div class="filter-bar" style="margin-bottom: 0.75rem;">
            <input type="text" id="searchReportIncome" class="search-input" placeholder="Search income..." />
            <div class="filter-controls">
                <input type="date" id="filterReportIncomeDate" />
                <button id="clearReportIncomeFilter" class="filter-btn">Clear</button>
            </div>
        </div>
        <div class="scrollable-table-wrapper">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="reportIncomeBody">
                        @foreach (var item in Model.Incomes)
                        {
                            <tr>
                                <td>@item.Source</td>
                                <td style="color: var(--success);">+@item.Amount.ToString("C")</td>
                                <td class="description-cell">@item.Description</td>
                                <td class="date-cell" data-raw="@item.Date.ToString("yyyy-MM-dd")">@item.Date.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                        @if (!Model.Incomes.Any())
                        {
                            <tr><td colspan="4" style="text-align: center;">No income records found</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- EXPENSE TABLE with its own filter + scroll -->
    <div style="margin-bottom: 2rem;">
        <h3><i class="fas fa-receipt"></i> Expense Records</h3>
        <div class="filter-bar" style="margin-bottom: 0.75rem;">
            <input type="text" id="searchReportExpense" class="search-input" placeholder="Search expense..." />
            <div class="filter-controls">
                <input type="date" id="filterReportExpenseDate" />
                <button id="clearReportExpenseFilter" class="filter-btn">Clear</button>
            </div>
        </div>
        <div class="scrollable-table-wrapper">
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Amount</th>
                            <th>Description</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="reportExpenseBody">
                        @foreach (var item in Model.Expenses)
                        {
                            <tr>
                                <td>@item.Category</td>
                                <td style="color: var(--danger);">-@item.Amount.ToString("C")</td>
                                <td class="description-cell">@item.Description</td>
                                <td class="date-cell" data-raw="@item.Date.ToString("yyyy-MM-dd")">@item.Date.ToString("MMM dd, yyyy")</td>
                            </tr>
                        }
                        @if (!Model.Expenses.Any())
                        {
                            <tr><td colspan="4" style="text-align: center;">No expense records found</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="footer-links">
        <a asp-controller="Dashboard" asp-action="Index" class="back-link">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
        @if (Model.Incomes.Any() || Model.Expenses.Any())
        {
            <a href="#" onclick="window.print();" class="back-link">
                <i class="fas fa-print"></i> Print Report
            </a>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Income table filter (report)
        const incSearch = document.getElementById('searchReportIncome');
        const incDate = document.getElementById('filterReportIncomeDate');
        const incClear = document.getElementById('clearReportIncomeFilter');
        const incRows = document.querySelectorAll('#reportIncomeBody tr');

        function filterReportIncome() {
            let term = incSearch ? incSearch.value.toLowerCase() : '';
            let date = incDate ? incDate.value : '';
            incRows.forEach(row => {
                let text = row.innerText.toLowerCase();
                let dateCell = row.querySelector('.date-cell');
                let rowDate = dateCell ? dateCell.getAttribute('data-raw') : '';
                let matchesSearch = text.includes(term);
                let matchesDate = (date === '' || rowDate === date);
                row.style.display = (matchesSearch && matchesDate) ? '' : 'none';
            });
        }
        if (incSearch) {
            incSearch.addEventListener('keyup', filterReportIncome);
            incDate.addEventListener('change', filterReportIncome);
            incClear.addEventListener('click', () => {
                incSearch.value = '';
                incDate.value = '';
                filterReportIncome();
            });
        }

        // Expense table filter (report)
        const expSearch = document.getElementById('searchReportExpense');
        const expDate = document.getElementById('filterReportExpenseDate');
        const expClear = document.getElementById('clearReportExpenseFilter');
        const expRows = document.querySelectorAll('#reportExpenseBody tr');

        function filterReportExpense() {
            let term = expSearch ? expSearch.value.toLowerCase() : '';
            let date = expDate ? expDate.value : '';
            expRows.forEach(row => {
                let text = row.innerText.toLowerCase();
                let dateCell = row.querySelector('.date-cell');
                let rowDate = dateCell ? dateCell.getAttribute('data-raw') : '';
                let matchesSearch = text.includes(term);
                let matchesDate = (date === '' || rowDate === date);
                row.style.display = (matchesSearch && matchesDate) ? '' : 'none';
            });
        }
        if (expSearch) {
            expSearch.addEventListener('keyup', filterReportExpense);
            expDate.addEventListener('change', filterReportExpense);
            expClear.addEventListener('click', () => {
                expSearch.value = '';
                expDate.value = '';
                filterReportExpense();
            });
        }
    </script>
}