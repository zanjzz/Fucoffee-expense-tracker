@model IEnumerable<Fucoffee.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<h2>Manage Users</h2>
<table>
    <thead>
        <tr>
            <th>Username</th>
            <th>Role</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Role</td>
                <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.UserId">Edit</a>
                    <a asp-action="Delete" asp-route-id="@user.UserId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<a asp-controller="Dashboard" asp-action="Index">Back to Dashboard</a>