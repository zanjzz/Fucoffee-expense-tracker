<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google" content="notranslate" />
    <meta http-equiv="Content-Language" content="en" />
    <title>@ViewData["Title"] — FUCOFFEE</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* --- FIX WHITE FLASH: immediate dark background --- */
        body {
            background-color: #000000 !important;
            background: transparent;
        }
        /* Ensure the Vanta container also has a black fallback */
        #vanta-bg {
            background-color: #000000;
        }
        /* Keep the grain texture but above the black background, behind content */
        body::before {
            z-index: -1;
            background-image: radial-gradient(circle at 20% 30%, rgba(198, 139, 94, 0.08) 1px, transparent 1px);
        }
        /* Slightly darken glass card for better contrast over fog */
        .main-content, .frosted-glass {
            background: rgba(25, 18, 14, 0.8);
            backdrop-filter: blur(12px);
        }
        
        /* Allow form pages to use full width without double box */
        .form-only-layout {
            padding: 0 !important;
            background: transparent !important;
            backdrop-filter: none !important;
            box-shadow: none !important;
            border: none !important;
        }
    </style>
</head>
<body>

    <!-- Vanta Background Container -->
    <div id="vanta-bg" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2; pointer-events: none; background-color: #000; opacity: 0; transition: opacity 1.5s ease;"></div>

    @if (Context.Session.GetString("Username") != null)
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

        <nav class="navbar">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                <img src="~/fucoffee.png" alt="FUCOFFEE Logo" style="height: 32px; width: auto; margin-right: 8px;" />
                FUCOFFEE
            </a>
            <div class="nav-links">
                <a asp-controller="Dashboard" asp-action="Index" class="@(currentController == "Dashboard" ? "active" : "")">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
                <a asp-controller="Income" asp-action="Index" class="@(currentController == "Income" ? "active" : "")">
                    <i class="fas fa-arrow-up"></i> Income
                </a>
                <a asp-controller="Expense" asp-action="Index" class="@(currentController == "Expense" ? "active" : "")">
                    <i class="fas fa-shopping-cart"></i> Expenses
                </a>
                <a asp-controller="Report" asp-action="Index" class="@(currentController == "Report" ? "active" : "")">
                    <i class="fas fa-file-alt"></i> Reports
                </a>
                @if (Context.Session.GetString("Role") == "Admin")
                {
                    <a asp-controller="User" asp-action="Index" class="@(currentController == "User" ? "active" : "")">
                        <i class="fas fa-users"></i> Users
                    </a>
                }
                <a asp-controller="Auth" asp-action="Logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </nav>
    }

    <!-- Content - Conditional class to remove double box on form pages -->
    <div class="page-wrapper" id="mainContentWrapper">
        <main class="@ViewData["MainClass"]">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
            (function() {
                function hideEmptyValidation() {
                    document.querySelectorAll('.validation-summary-errors').forEach(summary => {
                        if (summary.innerText.trim() === '') {
                            summary.style.display = 'none';
                        } else {
                            summary.style.display = 'block';
                        }
                    });
                }
                hideEmptyValidation();
                // optionally observe DOM changes if needed
                if (typeof MutationObserver !== 'undefined') {
                    const observer = new MutationObserver(hideEmptyValidation);
                    observer.observe(document.body, { childList: true, subtree: true });
                }
            })();
    </script>

    <!-- Vanta Fog Effect -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r121/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof VANTA !== 'undefined' && !window.vantaEffect) {
                window.vantaEffect = VANTA.FOG({
                    el: "#vanta-bg",
                    mouseControls: true,
                    touchControls: true,
                    gyroControls: false,
                    minHeight: 200.00,
                    minWidth: 200.00,
                    highlightColor: 0x3d1a00,
                    midtoneColor: 0x311608,
                    lowlightColor: 0x382d27,
                    baseColor: 0x0,
                    blurFactor: 0.71,
                    speed: 2.00,
                    zoom: 0.50
                });
                setTimeout(() => {
                    const bg = document.getElementById('vanta-bg');
                    if (bg) bg.style.opacity = '1';
                }, 100);
            }
        });

        window.addEventListener('beforeunload', function() {
            if (window.vantaEffect) window.vantaEffect.destroy();
        });
    </script>
</body>
</html>