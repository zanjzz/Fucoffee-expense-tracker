<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FUCOFFEE</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
            /* --- FIX WHITE FLASH: immediate dark background --- */
            body {
                background-color: #000000 !important;
                background: transparent; /* allow Vanta to show, but fallback is black */
            }
            /* Ensure the Vanta container also has a black fallback */
            #vanta-bg {
                background-color: #000000;
            }
            /* Keep the grain texture but above the black background, behind content */
            body::before {
                z-index: -1;
                background-image: radial-gradient(circle at 20% 30%, rgba(198, 139, 94, 0.08) 1px, transparent 1px);
            }
            /* Slightly darken glass card for better contrast over fog */
            .main-content, .frosted-glass {
                background: rgba(25, 18, 14, 0.8);
                backdrop-filter: blur(12px);
            }
    </style>
</head>
<body>

    <!-- Vanta Background Container (fixed behind everything, black fallback) -->
    <div id="vanta-bg" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2; pointer-events: none; background-color: #000; opacity: 0; transition: opacity 1.5s ease;"></div>

    @if (Context.Session.GetString("Username") != null)
    {
        <nav class="navbar">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-mug-hot"></i> FUCOFFEE
            </a>
            <div class="nav-links">
                <a asp-controller="Dashboard" asp-action="Index"><i class="fas fa-chart-line"></i> Dashboard</a>
                <a asp-controller="Income" asp-action="Index"><i class="fas fa-arrow-up"></i> Income</a>
                <a asp-controller="Expense" asp-action="Index"><i class="fas fa-shopping-cart"></i> Expenses</a>
                <a asp-controller="Report" asp-action="Index"><i class="fas fa-file-alt"></i> Reports</a>
                @if (Context.Session.GetString("Role") == "Admin")
                {
                    <a asp-controller="User" asp-action="Index"><i class="fas fa-users"></i> Users</a>
                }
                <a asp-controller="Auth" asp-action="Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
        </nav>
    }

    <div class="page-wrapper">
        <main class="main-content frosted-glass">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    /
    <!-- Vanta Fog Effect (scripts moved earlier but kept at bottom for performance) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r121/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
        if (typeof VANTA !== 'undefined' && !window.vantaEffect) {
        window.vantaEffect = VANTA.FOG({
        el: "#vanta-bg",
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
        highlightColor: 0x3d1a00,
        midtoneColor: 0x311608,
        lowlightColor: 0x382d27,
        baseColor: 0x0,
        blurFactor: 0.71,
        speed: 2.00,
        zoom: 0.50
        });
        // Fade in the background smoothly
        setTimeout(() => {
        const bg = document.getElementById('vanta-bg');
        if (bg) bg.style.opacity = '1';
        }, 100);
        }
        });

        window.addEventListener('beforeunload', function() {
        if (window.vantaEffect) window.vantaEffect.destroy();
        });
    </script> 
</body>
</html>