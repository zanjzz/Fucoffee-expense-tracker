@model Fucoffee.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — FUCOFFEE</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        /* Override the auth-wrapper background to transparent so Vanta shows */
        .auth-wrapper {
            background-color: transparent !important;
        }
        /* Hide empty validation summary (even if whitespace exists) */
        .validation-summary-errors:empty {
            display: none;
        }
        /* Center button */
        .auth-card .btn-primary {
            width: 100%;
            justify-content: center;
        }
        /* Error message styling */
        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.1);
            border-left: 3px solid #EF4444;
            padding: 0.75rem;
            border-radius: 12px;
            margin-bottom: 1.25rem;
            color: #EF4444;
            font-size: 0.9rem;
        }
        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.5rem;
        }
        body {
            background-color: #0A0A0A !important;
        }
    </style>
</head>
<body>
    <!-- Vanta Background Container -->
    <div id="vanta-bg" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2; pointer-events: none; background-color: #000; opacity: 0; transition: opacity 1.5s ease;"></div>

    <div class="auth-wrapper">
        <div class="auth-card">
            <div style="text-align: center; margin-bottom: 1.5rem;">
                <img src="~/fucoffee.png" alt="FUCOFFEE Logo" style="width: 80px; height: auto; margin-bottom: 1rem;" />
                <h2 style="margin-bottom: 0;">FUCOFFEE</h2>
                <p style="font-size: 0.8rem; color: var(--caramel-light); margin-top: 0.25rem;">Expense & Profit Tracking</p>
            </div>

            <form asp-action="Login" method="post">
                <!-- Only the summary validation, no field-level spans -->
                <div asp-validation-summary="All" class="validation-summary-errors"></div>

                <div>
                    <label asp-for="Username"></label>
                    <input asp-for="Username" placeholder="Enter username" />
                </div>
                <div>
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" placeholder="Enter password" />
                </div>

                <button type="submit" class="btn-primary">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>
            </form>

            <p style="text-align:center; margin-top:1rem; font-size:0.9rem">
                <a asp-action="Register">Don't have an account? Register</a>
            </p>
        </div>
    </div>

    <!-- Vanta scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r121/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.fog.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Hide empty validation summary (handles whitespace)
            const summary = document.querySelector('.validation-summary-errors');
            if (summary && summary.innerText.trim() === '') {
                summary.style.display = 'none';
            }

            if (typeof VANTA !== 'undefined' && !window.vantaEffect) {
                window.vantaEffect = VANTA.FOG({
                    el: "#vanta-bg",
                    mouseControls: true,
                    touchControls: true,
                    gyroControls: false,
                    minHeight: 200.00,
                    minWidth: 200.00,
                    highlightColor: 0x3d1a00,
                    midtoneColor: 0x311608,
                    lowlightColor: 0x382d27,
                    baseColor: 0x0,
                    blurFactor: 0.71,
                    speed: 2.00,
                    zoom: 0.50
                });
                setTimeout(() => {
                    const bg = document.getElementById('vanta-bg');
                    if (bg) bg.style.opacity = '1';
                }, 100);
            }
        });
        window.addEventListener('beforeunload', function() {
            if (window.vantaEffect) window.vantaEffect.destroy();
        });
    </script>
</body>
</html>