@{
    ViewData["MainClass"] = "form-only-layout";
}
@model Fucoffee.Models.Expense

<div class="form-page-container">
    <div class="floating-form-card">
        <h2>Edit Expense</h2>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <input type="hidden" asp-for="ExpenseId" />
            <input type="hidden" asp-for="RecordedBy" />

            <div class="form-group">
                <label asp-for="Category">Category</label>
                <input asp-for="Category" />
            </div>
            
            <div class="form-group">
                <label asp-for="Amount">Amount</label>
                @Html.TextBoxFor(m => m.Amount, "{0:F2}", new { type = "number", step = "0.01" })
            </div>
            
            <div class="form-group">
                <label asp-for="Description">Description</label>
                <input asp-for="Description" />
            </div>
            
            <div class="form-group">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" type="date" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-edit">
                    <i class="fas fa-edit"></i> Update Expense
                </button>
                <a asp-action="Index" class="btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.validation-summary-errors').forEach(summary => {
            if (summary.innerText.trim() === '') summary.style.display = 'none';
        });
    </script>
}