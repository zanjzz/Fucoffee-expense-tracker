@model Fucoffee.Models.Expense

<h2>Edit Expense</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="validation-summary-errors"></div>

    <input type="hidden" asp-for="ExpenseId" />
    <input type="hidden" asp-for="RecordedBy" />

    <div>
        <label asp-for="Category"></label>
        <input asp-for="Category" />
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Amount"></label>
        <input asp-for="Amount" type="number" step="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div>
        <label asp-for="Description"></label>
        <input asp-for="Description" />
    </div>
    <div>
        <label asp-for="Date"></label>
        <input asp-for="Date" type="date" />
    </div>

    <div class="btn-group">
        <button type="submit" class="btn-edit">
            <i class="fas fa-edit"></i> Update
        </button>
        <a asp-action="Index" class="btn-secondary">
            <i class="fas fa-times"></i> Cancel
        </a>
    </div>
</form>